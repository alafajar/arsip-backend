DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
PORT=3000
SEED_ADMIN_PASSWORD="ganti-dengan-password-kuat"
SEED_KAPRODI_PASSWORD="ganti-dengan-password-kuat"
JWT_ACCESS_SECRET="ganti-dengan-string-acak-panjang"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="ganti-dengan-string-acak-panjang-berbeda"
JWT_REFRESH_EXPIRES="7d"
CORS_ORIGIN="http://localhost:5173"
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=5
THROTTLE_REFRESH_LIMIT=10
TRUST_PROXY=false          # set ke 1 di belakang Nginx/Cloudflare
COOKIE_SECURE="false"        # true di production (wajib HTTPS)
COOKIE_SAME_SITE="lax"       # "none" jika frontend beda domain (wajib HTTPS)
